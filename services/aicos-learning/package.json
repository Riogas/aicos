{
  "name": "@aicos/learning",
  "version": "0.1.0",
  "private": true,
  "description": "AICOS Learning service. Captures run outcomes (provider/model/task_type/success/cost), aggregates them in Redis, and exposes /best-for to tell the Quota Manager which provider performs best for each task type.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "aicos-learning": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts --serve",
    "start": "node dist/index.js --serve",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
