{
  "name": "@aicos/tool-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "AICOS Tool Gateway. Proxy + audit + policy-gating para acciones de agentes contra servicios externos: github / docker / browser / shell. Cada acción consulta el Policy Engine ANTES de ejecutar.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "aicos-tool-gateway": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts --serve",
    "start": "node dist/index.js --serve",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
