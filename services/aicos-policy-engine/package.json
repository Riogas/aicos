{
  "name": "@aicos/policy-engine",
  "version": "0.1.0",
  "private": true,
  "description": "AICOS Policy Engine. Rule-based authz: evalúa si una acción de un actor sobre un recurso requiere aprobación humana, bloqueo, o pass-through. Inspired by F7.1 spec.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "aicos-policy-engine": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts --serve",
    "start": "node dist/index.js --serve",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
